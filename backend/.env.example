# ============================================================
# PLSP Lost & Found System - Backend Environment Variables
# File: backend/.env
#
# IMPORTANT: Never commit this file to Git!
# Add .env to your .gitignore file.
# ============================================================

# Server Configuration
PORT=8080
GIN_MODE=debug        # Change to "release" in production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=plsp_lost_found
DB_SSL_MODE=disable   # Change to "require" in production

# JWT Configuration
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_EXPIRY=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760   # 10MB in bytes

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@plsp.edu.ph
SMTP_PASS=your_email_password
